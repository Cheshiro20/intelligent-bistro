# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it's listed in .gitignore.

# === Required ===

# Anthropic API key — get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# === Optional: voice input via Whisper-compatible API ===
# If unset, the voice mic button is hidden and only text input works.
#
# Recommended: Groq (free, no credit card, fast):
#   1. Sign up at https://console.groq.com
#   2. Create an API key
#   3. Uncomment the three lines below
#
# WHISPER_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WHISPER_BASE_URL=https://api.groq.com/openai/v1/audio/transcriptions
# WHISPER_MODEL=whisper-large-v3-turbo
#
# Alternative: OpenAI (paid ~$0.006/min):
#   WHISPER_API_KEY=sk-proj-xxxxxxxxxxxxx
#   (leave WHISPER_BASE_URL and WHISPER_MODEL unset to use OpenAI defaults)


# === Server ===
PORT=3000
